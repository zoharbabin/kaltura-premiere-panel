{
  "manifestVersion": 5,
  "id": "163a7b84",
  "name": "Kaltura",
  "version": "1.18.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "kalturaMediaBrowser",
      "label": {
        "default": "Media Browser"
      },
      "minimumSize": {
        "width": 280,
        "height": 400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 500,
        "height": 700
      }
    },
    {
      "type": "panel",
      "id": "kalturaPublish",
      "label": {
        "default": "Publish"
      },
      "minimumSize": {
        "width": 280,
        "height": 400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 500,
        "height": 700
      }
    },
    {
      "type": "command",
      "id": "kalturaSettings",
      "label": {
        "default": "Settings"
      }
    },
    {
      "type": "command",
      "id": "kalturaSignOut",
      "label": {
        "default": "Sign Out"
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "https://*.kaltura.com",
        "https://*.kaltura.cloud",
        "wss://*.kaltura.com",
        "https://*.akamaihd.net",
        "https://*.cloudfront.net"
      ]
    },
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["https"],
      "extensions": []
    },
    "webview": {
      "allow": "yes",
      "domains": ["https://*.kaltura.com"]
    },
    "clipboard": "readAndWrite",
    "enableUserInfo": true
  },
  "featureFlags": {
    "enableSWCSupport": true,
    "enableAlerts": true
  },
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon-24.png",
      "scale": [1, 2],
      "theme": ["all"]
    },
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon-48.png",
      "scale": [1, 2],
      "theme": ["all"]
    },
    {
      "width": 96,
      "height": 96,
      "path": "icons/icon-96.png",
      "scale": [1, 2],
      "theme": ["all"]
    },
    {
      "width": 192,
      "height": 192,
      "path": "icons/icon-192.png",
      "scale": [1, 2],
      "theme": ["all"]
    }
  ]
}
